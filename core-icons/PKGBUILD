# Maintainer: m4teo.dev <m4teo.dev>

pkgname=core-icons
pkgdesc="Base icons for Core Linux"
pkgver=r9.7e9cf3d
pkgrel=3
arch=('any')
url="https://github.com/Core-Linux/core-icons"
license=('GPL')
makedepends=('git')
depends=('hicolor-icon-theme')

source=("core-icons::git+https://github.com/Core-Linux/core-icons.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/core-icons"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  install -Dm644 \
    "$srcdir/core-icons/usr/share/icons/corelinux.png" \
    "$pkgdir/usr/share/icons/corelinux.png"
}
